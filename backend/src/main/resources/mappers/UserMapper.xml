<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.demo.mapper.UserMapper">
    <cache/>
    <resultMap id="userMap" type="com.example.demo.entity.User">
        <id property="id" column="id"/>
        <result property="username" column="username"/>
        <result property="password" column="password"/>
        <result property="realname" column="real_name"/>
    </resultMap>


    <select id="selectByConditions" parameterType="com.example.demo.entity.User" resultMap="userMap" useCache="true">
        <!--
  这里的id必须和接口中的方法名一致
        -->
        select * from user where 1=1
        <if test="username != null and username !=''">
           and username=#{username}
        </if>
        <if test="password != null and password !=''">
            and password= #{password}
        </if>
    </select>

    <insert id="saveBean" parameterType="com.example.demo.entity.User">
        insert into user(username,password,real_name) values(#{username},#{password},#{realname})
    </insert>

    <insert id="insertList" parameterType="com.example.demo.entity.User">
        insert into user(username,password,real_name)
        values
        <foreach collection="users" item="bean" separator=",">
            (#{bean.username},#{bean.password},#{bean.realname})
        </foreach>

    </insert>

    <update id="update" parameterType="com.example.demo.entity.User">
        update user set username=#{username},password=#{password},real_name=#{realname} where id=#{id}
    </update>

    <delete id="delete" parameterType="long">
        delete from user where id=#{id}
    </delete>




</mapper>